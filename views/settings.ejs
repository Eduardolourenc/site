<%- include('layout', { body: `

<section class="page-header">
  <div>
    <h1><i class="ph-duotone ph-gear"></i> Configurações e Metas</h1>
    <p>Ajuste sua meta diária de estudos e personalize a sua experiência.</p>
  </div>
</section>

<section class="layout-single-col card">
  <form action="/settings" method="POST" class="animate__animated animate__fadeIn">
    
    <div class="form-group">
      <label for="daily_goal"><i class="ph-duotone ph-target"></i> Meta Diária de Estudo (em horas)</label>
      <input type="number" id="daily_goal" name="daily_goal" class="form-control" min="1" max="24" step="0.5" value="${goal}" required>
      <small style="color: var(--text-muted); display: block; margin-top: 0.5rem;">
        Esta meta será usada para alimentar a barra de progresso no seu Dashboard em tempo real.
      </small>
    </div>

    <div class="form-actions" style="margin-top: 2rem;">
      <button type="submit" class="btn"><i class="ph-bold ph-floppy-disk"></i> Salvar Configurações</button>
    </div>
  </form>
</section>

` }) %>