<%- include('layout', { body: `
<section class="page-header">
  <div>
    <h1><i class="ph-duotone ph-timer"></i> Nova sessão de estudo</h1>
    <p>Use o cronômetro para controlar seu foco e registre tudo em poucos cliques.</p>
  </div>
</section>

<section class="layout-two-cols">
  <article class="card focus-card">
    <h2><i class="ph-duotone ph-hourglass-high"></i> Cronômetro</h2>
    <div class="timer focus-timer">
      <span id="timer-display" class="timer-display">00:00:00</span>
      <div class="timer-buttons">
        <button type="button" class="btn-secondary" id="timer-start"><i class="ph-fill ph-play"></i> Iniciar</button>
        <button type="button" class="btn-secondary" id="timer-pause"><i class="ph-fill ph-pause"></i> Pausar</button>
        <button type="button" class="btn-secondary" id="timer-reset"><i class="ph-bold ph-arrow-counter-clockwise"></i> Zerar</button>
        <button type="button" class="btn-primary" id="timer-transfer" style="background: rgba(139, 92, 246, 0.4);"><i class="ph-bold ph-arrow-right"></i> Usar Tempo</button>
      </div>
      <p class="hint">Você pode deixar o cronômetro rolando enquanto estuda. Ao salvar, o tempo vai direto para o campo de horas (pode ajustar depois).</p>
    </div>
  </article>

  <article class="card">
    <h2><i class="ph-duotone ph-note-pencil"></i> Registrar sessão</h2>
    <form method="POST" action="/study" class="form-grid">
      <label>
        Data
        <input type="date" name="date" value="${new Date().toISOString().slice(0,10)}" required />
      </label>

      <label>
        Matéria
        <select name="subject_id" required>
          ${subjects.map(s => `<option value="${s.id}">${s.name}</option>`).join('')}
        </select>
        <small><a href="/subjects">Gerenciar matérias</a></small>
      </label>

      <div style="display: flex; gap: 1rem;">
        <label style="flex: 1;">
          Horas
          <input type="number" step="1" min="0" name="hours" id="hours-input" placeholder="0" />
        </label>
        <label style="flex: 1;">
          Minutos
          <input type="number" step="1" min="0" max="59" name="minutes" id="minutes-input" placeholder="0" />
        </label>
      </div>

      <label>
        Questões feitas (Opcional)
        <input type="number" min="0" name="questions" />
      </label>

      <label>
        Questões corretas (Opcional)
        <input type="number" min="0" name="correct" />
      </label>

      <button type="submit" class="btn-primary" style="grid-column: 1 / -1;"><i class="ph-bold ph-check"></i> Salvar sessão</button>
    </form>
  </article>
</section>

<script>
  (function() {
    const display = document.getElementById('timer-display');
    const startBtn = document.getElementById('timer-start');
    const pauseBtn = document.getElementById('timer-pause');
    const resetBtn = document.getElementById('timer-reset');
    const transferBtn = document.getElementById('timer-transfer');
    const hoursInput = document.getElementById('hours-input');
    const minutesInput = document.getElementById('minutes-input');
    const form = document.querySelector('form[action="/study"]');

    if (!display || !startBtn || !pauseBtn || !resetBtn || !transferBtn || !form) return;

    let startTime = null;
    let elapsedMs = 0;
    let timerId = null;

    function format(ms) {
      const totalSeconds = Math.floor(ms / 1000);
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      const pad = n => String(n).padStart(2, '0');
      return pad(hours) + ':' + pad(minutes) + ':' + pad(seconds);
    }

    function updateDisplay() {
      const now = Date.now();
      const ms = elapsedMs + (startTime ? (now - startTime) : 0);
      display.textContent = format(ms);
    }

    function start() {
      if (timerId) return;
      startTime = Date.now();
      timerId = setInterval(updateDisplay, 1000);
    }

    function pause() {
      if (!timerId) return;
      clearInterval(timerId);
      timerId = null;
      if (startTime) {
        elapsedMs += Date.now() - startTime;
        startTime = null;
      }
      updateDisplay();
    }

    function reset() {
      if (timerId) clearInterval(timerId);
      timerId = null;
      startTime = null;
      elapsedMs = 0;
      display.textContent = '00:00:00';
    }

    startBtn.addEventListener('click', start);
    pauseBtn.addEventListener('click', pause);
    resetBtn.addEventListener('click', reset);
    
    transferBtn.addEventListener('click', function() {
      pause(); // Pausa automaticamente
      const totalSeconds = Math.floor(elapsedMs / 1000);
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      
      if (hours > 0 || minutes > 0) {
        if (hoursInput) hoursInput.value = hours;
        if (minutesInput) minutesInput.value = minutes;
        
        transferBtn.innerHTML = '<i class="ph-bold ph-check"></i> Preenchido!';
        setTimeout(() => {
           transferBtn.innerHTML = '<i class="ph-bold ph-arrow-right"></i> Usar Tempo';
        }, 2000);
      }
    });

    // Removemos a interceptação no evento 'submit' da form para não sobrescrever caso o usuário edite o valor manualmente
  })();
</script>
` }) %>
