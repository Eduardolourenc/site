<%- include('layout', { body: `
<section class="page-header">
  <div>
    <h1><i class="ph-duotone ph-squares-four"></i> Painel de estudos</h1>       
    <p>Visão geral rápida do seu progresso recente.</p>
  </div>
  <a href="/study" class="btn-primary"><i class="ph-bold ph-play"></i> Iniciar sessão de estudo</a>
</section>

<!-- Insights -->
${insight ? `
<section class="card animate__animated animate__fadeInDown" style="margin-bottom: 2rem; background: rgba(139, 92, 246, 0.1); border-left: 4px solid var(--primary);">
  <p style="margin: 0; font-weight: 500; color: var(--text-light);"><i class="ph-fill ph-lightbulb"></i> ${insight}</p>
</section>
` : ''}

<section class="cards-grid">
  <!-- Card de Hoje com Progresso da Meta -->
  <article class="stat-card" style="grid-column: span 3; display: flex; flex-direction: column; gap: 1rem;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h2>Hoje (Meta: ${dailyGoal}h)</h2>
        <p class="stat-main">${todayHoursFmt}</p>
        <p class="stat-sub">${todayStats.total_questions || 0} questões &middot; ${todayStats.total_correct || 0} acertos</p>
      </div>
      <div class="stat-icon" style="align-self: flex-start;"><i class="ph-duotone ph-target"></i></div>
    </div>
    
    <!-- Barra de progresso -->
    <div style="width: 100%; height: 12px; background: rgba(255,255,255,0.1); border-radius: 6px; overflow: hidden; margin-top: 1rem;">
      <div style="height: 100%; width: ${Math.min((todayStats.total_hours / dailyGoal) * 100, 100)}%; background: var(--primary); transition: width 1s ease-in-out;"></div>
    </div>
    <p class="stat-sub" style="text-align: right; margin-top: -0.5rem;">${Math.round((todayStats.total_hours / dailyGoal) * 100)}% concluído</p>
  </article>

  <article class="stat-card" style="grid-column: span 1.5;">
    <div class="stat-icon"><i class="ph-duotone ph-calendar-blank"></i></div>   
    <h2>Últimos 7 dias</h2>
    <p class="stat-main">${weekHours}</p>
    <p class="stat-sub">Tempo total estudado</p>
  </article>

  <article class="stat-card" style="grid-column: span 1.5;">
    <div class="stat-icon"><i class="ph-duotone ph-calendar"></i></div>
    <h2>Este mês</h2>
    <p class="stat-main">${monthHours}</p>
    <p class="stat-sub">Horas registradas no mês atual</p>
  </article>
</section>

<section class="card">
  <div class="card-header-row">
    <h2><i class="ph-duotone ph-clock-counter-clockwise"></i> Últimos estudos</h2>
    <a href="/history" class="link-inline">Ver histórico completo <i class="ph-bold ph-arrow-right"></i></a>
  </div>
  <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
    <thead>
      <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">
        <th style="padding: 1rem 0;">Data</th>
        <th>Matéria</th>
        <th>Tempo</th>
        <th>Questões</th>
        <th>Acertos</th>
        <th>Aproveitamento</th>
      </tr>
    </thead>
    <tbody>
      ${sessions.length === 0 ? `
        <tr>
          <td colspan="6" class="hint" style="padding: 1rem 0;">Nenhum estudo registrado ainda. Comece clicando em "Iniciar sessão de estudo".</td>
        </tr>
      ` : sessions.map(s => `
        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
          <td style="padding: 1rem 0;">${s.date}</td>
          <td>${s.subject_name}</td>
          <td>${s.formatted_time}</td>
          <td>${s.questions}</td>
          <td>${s.correct}</td>
          <td>
            <span class="badge" style="background: rgba(16, 185, 129, 0.15); border-color: rgba(16, 185, 129, 0.3); color: #34d399;">
              ${s.accuracy}
            </span>
          </td>
        </tr>
      `).join('')}
    </tbody>
  </table>
</section>
` }) %>