<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Monitoramento de Estudos</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Google Fonts: Poppins -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- Phosphor Icons (Ícones modernos) -->
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <!-- Animate.css para animações -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="animate__animated animate__fadeIn">
  <header class="top-bar">
    <div style="display: flex; align-items: center; gap: 1rem;">
      <h1><i class="ph-fill ph-student"></i> MonitoraStudy</h1>
      <% if (typeof streak !== 'undefined') { %>
        <div title="Dias seguidos batendo a meta!" class="streak-badge <%= goalMetToday ? 'met' : 'not-met' %>">
          <i class="ph-fill ph-fire"></i> <%= streak %>
        </div>
      <% } %>
    </div>
    <nav>
      <a href="/dashboard"><i class="ph ph-squares-four"></i> Dashboard</a>
      <a href="/study"><i class="ph ph-timer"></i> Estudar</a>
      <a href="/pomodoro"><i class="ph ph-clock"></i> Pomodoro</a>
      <a href="/history"><i class="ph ph-clock-counter-clockwise"></i> Histórico</a>
      <a href="/subjects"><i class="ph ph-books"></i> Matérias</a>
      <a href="/report"><i class="ph ph-chart-bar"></i> Relatórios</a>
      <a href="/calendar"><i class="ph ph-calendar"></i> Calendário</a>
      <a href="/settings"><i class="ph ph-gear"></i> Metas</a>
    </nav>
  </header>

  <main class="container">
    <%- body %>
  </main>

  <footer class="footer" style="display:flex; justify-content:space-between; align-items:center; padding: 1rem 2rem;">
    <span>Feito para acompanhar seus estudos</span>
    <a href="/export" class="btn-secondary" style="font-size: 0.8rem; padding: 0.4rem 0.8rem;"><i class="ph-bold ph-download-simple"></i> Backup do Banco</a>
  </footer>
</body>
</html>
